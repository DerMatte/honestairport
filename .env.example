# Required for scripts/generate-airport.ts (Vercel AI Gateway with xAI access)
AI_GATEWAY_API_KEY=

# Required for scripts/review-airport-pages.ts (Cursor SDK local agent)
# Create at https://cursor.com/dashboard/integrations
CURSOR_API_KEY=

# Postgres connection for user reviews (any provider: Neon, Supabase, RDS, ...).
# Without it the site still works - review sections degrade gracefully.
# For local development, `pnpm db:dev` boots a disposable Postgres:
# DATABASE_URL=postgres://dev:dev@127.0.0.1:54329/honestairport
DATABASE_URL=

# Better Auth (logins). Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# http://localhost:3000 in dev, https://<domain> in production
BETTER_AUTH_URL=

# Only this account may post reviews (must have a verified email).
OWNER_EMAIL=

# Optional social logins - the buttons only render when the vars are set.
# GitHub OAuth app callback: <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Apple Services ID + pre-generated ES256 client-secret JWT (<=180 days,
# rotate before expiry). Return URL: <BETTER_AUTH_URL>/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
